# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment and Python packages
venv/
env/
*.egg
*.egg-info/
dist/
build/
pip-wheel-metadata/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Data files
data/
!data/datasets/preprocessed/*

# Model files and checkpoints
models/

# Experiment tracking logs
experiments/

# Generated outputs (images, plots, etc.)
outputs/

# Configuration and environment files
config.yaml
.env

# DS_Store and system files
.DS_Store
Thumbs.db

# JupyterLab and VSCode settings
.vscode/
.jupyter/
.history/
workspace/

# Temporary files
*.bak
*.tmp
*.log
*.swp
*.swo

# Large file types (optional, if you want to exclude them)
*.h5
*.bin
*.ckpt
*.pt
*.tflite

# Pytest
.cache/
.pytest_cache/

# Logs
*.log
*.out
*.err

# Ignore large files tracked by DVC (if using it for datasets/models)
*.dvc
.cache/